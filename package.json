{
  "name": "dental-chatbot-experiment",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "validate:kb": "tsx scripts/validate-kb.ts",
    "validate:kb-format": "tsx scripts/validate-kb-format.ts",
    "validate:scenarios": "tsx scripts/validate-scenarios.ts",
    "validate:pe-prompt": "tsx scripts/validate-pe-prompt.ts",
    "validate:rag": "tsx scripts/validate-rag.ts",
    "validate:experiment-logging": "tsx scripts/validate-experiment-logging.ts",
    "validate:experiment-runner": "tsx scripts/validate-experiment-runner.ts",
    "validate:api": "tsx scripts/validate-api.ts",
    "validate:analysis": "tsx scripts/validate-analysis.ts",
    "mock:evaluations": "tsx scripts/mock-evaluations.ts",
    "smoke:db": "node --env-file-if-exists=.env --import tsx scripts/smoke-db.ts",
    "prepare:embeddings": "node --env-file-if-exists=.env --import tsx scripts/prepare-embeddings.ts",
    "validate:data": "npm run validate:kb && npm run validate:kb-format && npm run validate:scenarios"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "next": "^16.2.6",
    "openai": "^6.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "prisma": "6.19.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
